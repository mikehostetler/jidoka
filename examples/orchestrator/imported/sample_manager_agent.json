{
  "agent": {
    "id": "sample_manager_agent",
    "context": {
      "tenant": "demo",
      "channel": "orchestrator_imported"
    }
  },
  "defaults": {
    "model": "fast",
    "instructions": "You are an orchestration manager. Use research_agent for research tasks and writer_specialist for writing tasks. Delegate to exactly one specialist when appropriate, then answer with the specialist result."
  },
  "capabilities": {
    "subagents": [
      {
        "agent": "research_agent",
        "as": "research_agent",
        "description": "Ask the research specialist for concise factual notes",
        "target": "ephemeral",
        "timeout_ms": 30000,
        "forward_context": {
          "mode": "only",
          "keys": [
            "tenant",
            "channel",
            "session"
          ]
        },
        "result": "structured"
      },
      {
        "agent": "writer_specialist",
        "description": "Ask the writing specialist to draft or rewrite polished copy",
        "target": "ephemeral",
        "timeout_ms": 30000,
        "forward_context": {
          "mode": "except",
          "keys": [
            "session"
          ]
        },
        "result": "text"
      }
    ]
  }
}
