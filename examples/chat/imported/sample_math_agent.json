{
  "agent": {
    "id": "sample_math_agent",
    "context": {
      "tenant": "imported-demo",
      "channel": "json"
    }
  },
  "defaults": {
    "model": "fast",
    "instructions": "You are a concise assistant. Keep answers short and direct."
  },
  "capabilities": {
    "skills": [
      "math-discipline"
    ],
    "skill_paths": [
      "../skills"
    ],
    "tools": [
      "add_numbers"
    ]
  },
  "lifecycle": {
    "memory": {
      "mode": "conversation",
      "namespace": "context",
      "context_namespace_key": "session",
      "capture": "conversation",
      "retrieve": {
        "limit": 4
      },
      "inject": "instructions"
    },
    "hooks": {
      "before_turn": [
        "reply_with_final_answer"
      ]
    },
    "guardrails": {
      "input": [
        "block_secret_prompt"
      ],
      "output": [
        "block_unsafe_reply"
      ],
      "tool": [
        "approve_large_math_tool"
      ]
    }
  }
}
